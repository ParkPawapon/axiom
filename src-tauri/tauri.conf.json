{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AxiomPHP",
  "version": "0.1.0",
  "identifier": "com.axiomphp.desktop",
  "build": {
    "beforeDevCommand": "bun dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AxiomPHP",
        "label": "main",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
