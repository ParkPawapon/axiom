{
  "name": "axiomphp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.23",
  "scripts": {
    "dev": "bun node_modules/vite/bin/vite.js",
    "build": "bun node_modules/typescript/bin/tsc -b && bun node_modules/vite/bin/vite.js build",
    "preview": "bun node_modules/vite/bin/vite.js preview",
    "tauri": "bun node_modules/@tauri-apps/cli/tauri.js",
    "tauri:dev": "bun node_modules/@tauri-apps/cli/tauri.js dev",
    "tauri:build": "bun node_modules/@tauri-apps/cli/tauri.js build",
    "lint": "bun node_modules/eslint/bin/eslint.js .",
    "typecheck": "bun node_modules/typescript/bin/tsc -b --pretty",
    "format": "bun node_modules/prettier/bin/prettier.cjs . --write"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.1",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.8.4",
    "@types/node": "^25.8.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.39.0",
    "vite": "^8.0.13"
  }
